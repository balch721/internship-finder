<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Find your match — Aryan's Internship Finder</title>
<style>
  :root{
    --bg:#0e1116; --panel:#171b22; --panel2:#1e232c; --border:#2a313c;
    --text:#e6e9ef; --muted:#9aa4b2; --accent:#5b8cff; --accent2:#9b6bff; --up:#36d399; --gold:#e8b339;
  }
  *{box-sizing:border-box}
  button,input,textarea,select{color:var(--text)}
  body{margin:0;min-height:100vh;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    background:radial-gradient(1100px 560px at 70% -12%,rgba(91,140,255,.16),transparent 60%),radial-gradient(800px 460px at 12% 10%,rgba(155,107,255,.12),transparent 55%),var(--bg);
    color:var(--text);line-height:1.6}
  .wrap{max-width:680px;margin:0 auto;padding:0 24px 60px}
  .top{display:flex;align-items:center;justify-content:space-between;padding:22px 0 6px}
  .home{color:var(--accent);text-decoration:none;font-size:13px;font-weight:600;transition:opacity .2s}
  .home:hover{opacity:.7}
  #survey{max-width:600px;margin:24px auto 0;background:var(--panel);border:1px solid var(--border);border-radius:18px;padding:24px 26px 22px;box-shadow:0 18px 50px rgba(0,0,0,.32);overflow:hidden}
  .progwrap{margin-top:0}
  .progbar{height:7px;background:#232a36;border-radius:6px;overflow:hidden}
  .progbar > i{display:block;height:100%;width:0;background:linear-gradient(90deg,var(--accent),var(--accent2));transition:width .45s cubic-bezier(.2,.7,.2,1)}
  .progtext{color:var(--muted);font-size:12px;margin-top:7px}

  /* question card with slide transition */
  .stage{position:relative;margin-top:26px}
  .q{min-height:300px;animation:slideIn .42s cubic-bezier(.2,.7,.2,1) both}
  .q.leaving{animation:slideOut .32s cubic-bezier(.4,0,1,1) both}
  @keyframes slideIn{from{opacity:0;transform:translateX(34px)}to{opacity:1;transform:none}}
  @keyframes slideOut{from{opacity:1;transform:none}to{opacity:0;transform:translateX(-34px)}}
  .qnum{font-size:12px;letter-spacing:1.5px;text-transform:uppercase;color:var(--accent);font-weight:700}
  .qtitle{font-size:24px;font-weight:750;margin:8px 0 4px;letter-spacing:-.3px}
  .qhint{color:var(--muted);font-size:13.5px;margin-bottom:18px}
  .opts{display:grid;gap:11px}
  .opt{display:flex;align-items:center;gap:12px;background:var(--panel);border:1px solid var(--border);border-radius:13px;
    padding:15px 16px;cursor:pointer;font-size:15px;transition:transform .16s,border-color .16s,background .16s;text-align:left}
  .opt:hover{transform:translateX(4px);border-color:var(--accent)}
  .opt.sel{border-color:var(--accent);background:rgba(91,140,255,.12)}
  .opt .em{font-size:20px}
  .opt .ck{margin-left:auto;color:var(--accent);font-weight:700;opacity:0;transition:opacity .15s}
  .opt.sel .ck{opacity:1}
  .chips{display:flex;flex-wrap:wrap;gap:9px}
  .chip{background:var(--panel);border:1px solid var(--border);border-radius:999px;padding:9px 15px;cursor:pointer;font-size:14px;transition:transform .16s,border-color .16s,background .16s}
  .chip:hover{transform:translateY(-2px);border-color:var(--accent)}
  .chip.sel{background:var(--accent);border-color:var(--accent);color:#fff}
  input[type=text],textarea{width:100%;background:var(--panel2);border:1px solid var(--border);color:var(--text);
    padding:13px 14px;border-radius:12px;font-size:15px;outline:none;font-family:inherit}
  input:focus,textarea:focus{border-color:var(--accent)}
  textarea{min-height:120px;resize:vertical}
  .drop{margin-top:10px;border:2px dashed var(--border);border-radius:12px;padding:18px;text-align:center;cursor:pointer;transition:.15s;font-size:13.5px;color:var(--muted)}
  .drop:hover,.drop.drag{border-color:var(--accent);color:var(--text)}
  .nav{display:flex;justify-content:space-between;align-items:center;margin-top:26px}
  .btn{background:var(--accent);color:#fff;border:none;font-size:15px;font-weight:650;padding:12px 26px;border-radius:12px;cursor:pointer;transition:background .2s,transform .12s}
  .btn:hover{background:#4a7bf0} .btn:active{transform:scale(.97)} .btn:disabled{opacity:.45;cursor:default}
  .back{background:none;border:none;color:var(--muted);font-size:14px;cursor:pointer;padding:8px 4px;transition:color .2s}
  .back:hover{color:var(--text)}
  .skip{background:none;border:none;color:var(--muted);font-size:13px;cursor:pointer;text-decoration:underline;margin-top:12px}
  .skip:hover{color:var(--text)}

  /* results */
  #results{display:none;animation:rise .5s both}
  @keyframes rise{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
  h1{font-size:25px;margin:6px 0 2px}
  .rsub{color:var(--muted);font-size:13.5px;margin-bottom:6px}
  .yourtags{display:flex;flex-wrap:wrap;gap:6px;margin:10px 0 18px}
  .yt{font-size:11.5px;padding:3px 9px;border-radius:999px;background:#222a36;color:#bcd0ff}
  .rcard{background:var(--panel);border:1px solid var(--border);border-radius:14px;padding:16px 18px;margin-bottom:12px;position:relative;transition:border-color .2s,transform .2s}
  .rcard:hover{border-color:var(--accent);transform:translateY(-2px)}
  .score{position:absolute;top:15px;right:16px;font-weight:800;font-size:14px}
  .score.hi{color:var(--up)} .score.mid{color:var(--gold)} .score.lo{color:var(--muted)}
  .rco{color:var(--accent);font-weight:600;font-size:13px}
  .rrole{font-size:16px;font-weight:650;margin:1px 0 2px}
  .rmeta{color:var(--muted);font-size:12.5px}
  .sectlabel{display:inline-block;font-size:10.5px;font-weight:700;padding:2px 8px;border-radius:6px;background:#222a36;color:#bcd0ff;margin-bottom:6px}
  .why{font-size:12px;color:var(--muted);margin-top:7px}
  .mk{display:inline-block;font-size:11px;padding:2px 7px;border-radius:6px;background:rgba(54,211,153,.12);color:#8fe6bf;border:1px solid rgba(54,211,153,.25);margin:3px 4px 0 0}
  .rapply{display:inline-block;margin-top:9px;color:var(--accent);font-weight:600;font-size:13px;text-decoration:none}
  .restart{margin:20px auto 0;display:block;background:var(--panel2);border:1px solid var(--border);color:var(--text);font-size:13.5px;font-weight:600;padding:11px 20px;border-radius:11px;cursor:pointer}
  .restart:hover{border-color:var(--accent)}
  .note{background:#241c12;border:1px solid #5a4520;color:#f3c98b;font-size:12.5px;padding:9px 12px;border-radius:10px;margin:6px 0 16px}
</style>
<script src="transition.js?v=4"></script>
</head>
<body>
<div class="wrap">
  <div class="top">
    <a class="home" href="index.html">← Aryan's Internship Finder</a>
  </div>

  <!-- SURVEY -->
  <div id="survey">
    <div class="progwrap">
      <div class="progbar"><i id="progfill"></i></div>
      <div class="progtext" id="progtext"></div>
    </div>
    <div class="stage" id="stage"></div>
    <div class="nav">
      <button class="back" id="backBtn">← Back</button>
      <button class="btn" id="nextBtn">Next →</button>
    </div>
  </div>

  <!-- RESULTS -->
  <div id="results">
    <h1>🎯 Your personalized matches</h1>
    <div class="rsub" id="rsub"></div>
    <div class="yourtags" id="yourtags"></div>
    <div id="rlist"></div>
    <button class="restart" id="restartBtn">↺ Retake the survey</button>
  </div>
</div>

<script src="data.js"></script>
<script src="data_analytics.js"></script>
<script>
/* ---------------- combined dataset ---------------- */
function buildPool(){
  const pool=[];
  (window.INTERNSHIPS||[]).forEach(d=>pool.push({d, c:(window.COMPANIES||{})[d.company]||{}, section:"Consulting & Business Systems"}));
  (window.ANALYTICS_INTERNSHIPS||[]).forEach(d=>pool.push({d, c:(window.ANALYTICS_COMPANIES||{})[d.company]||{}, section:"Data & Business Analytics"}));
  return pool;
}

/* ---------------- survey definition ---------------- */
const survey = {
  answers: { field:null, major:"", interests:"", grad:null, size:null, location:null, resume:"" },
  questions: [
    { id:"field", type:"single", num:"Question 1",
      title:"What field interests you most?",
      hint:"Pick the closest fit — you can refine next.",
      options:[
        {v:"business",em:"💼",label:"Business"},
        {v:"cs",em:"💻",label:"Computer Science & Tech"},
        {v:"engineering",em:"⚙️",label:"Engineering"},
        {v:"med",em:"🧬",label:"Healthcare & Medicine"},
        {v:"unsure",em:"🤔",label:"Not sure yet"}
      ]},
    { id:"major", type:"text", num:"Question 2",
      title:"What's your major (or intended major)?",
      hint:"Free text — e.g. \"Industrial Engineering\", \"Economics\", \"Computer Science\".",
      placeholder:"Type your major…" },
    { id:"interests", type:"textarea", num:"Question 3",
      title:"What are you interested in?",
      hint:"Type freely — roles, industries, skills, topics, anything. E.g. \"agentic AI, healthcare strategy, process improvement, working with data.\"",
      placeholder:"I'm interested in…" },
    { id:"grad", type:"single", num:"Question 4",
      title:"When do you graduate?",
      hint:"Helps match the right program level.",
      options:[
        {v:"2027",em:"🎓",label:"2027"},
        {v:"2028",em:"🎓",label:"2028"},
        {v:"2029",em:"🎓",label:"2029"},
        {v:"2030+",em:"🎓",label:"2030 or later"}
      ]},
    { id:"size", type:"single", num:"Question 5",
      title:"What kind of company appeals to you?",
      hint:"We'll weight your matches accordingly.",
      options:[
        {v:"large",em:"🏢",label:"Large / well-known (Fortune 500)"},
        {v:"startup",em:"🚀",label:"Startup / high-growth"},
        {v:"any",em:"🌐",label:"No preference"}
      ]},
    { id:"location", type:"single", num:"Question 6",
      title:"Where do you want to work?",
      hint:"",
      options:[
        {v:"any",em:"🇺🇸",label:"Anywhere in the US"},
        {v:"remote",em:"🏡",label:"Prefer remote"},
        {v:"hub",em:"📍",label:"A specific city / hub"}
      ]},
    { id:"resume", type:"resume", num:"Last step (optional)",
      title:"Want even better matches? Add your resume.",
      hint:"Optional — paste it or drop a file and we'll factor in your skills. Skip if you'd rather not." }
  ]
};

let step = 0;
const $ = id => document.getElementById(id);

function renderStep(dir){
  const q = survey.questions[step];
  const stage = $("stage");
  // progress
  $("progfill").style.width = ((step)/(survey.questions.length)*100)+"%";
  $("progtext").textContent = `Step ${step+1} of ${survey.questions.length}`;
  $("backBtn").style.visibility = step===0 ? "hidden" : "visible";
  $("nextBtn").textContent = step===survey.questions.length-1 ? "See my matches →" : "Next →";

  let body = "";
  if(q.type==="single"){
    body = `<div class="opts">`+ q.options.map(o=>
      `<button class="opt ${survey.answers[q.id]===o.v?'sel':''}" data-v="${o.v}"><span class="em">${o.em}</span>${o.label}<span class="ck">✓</span></button>`
    ).join("") +`</div>`;
  } else if(q.type==="text"){
    body = `<input type="text" id="txtIn" placeholder="${q.placeholder||''}" value="${(survey.answers[q.id]||'').replace(/"/g,'&quot;')}">`;
  } else if(q.type==="textarea"){
    body = `<textarea id="taIn" placeholder="${q.placeholder||''}">${(survey.answers[q.id]||'')}</textarea>`;
  } else if(q.type==="resume"){
    body = `<textarea id="resIn" placeholder="Paste resume text here (optional)…">${(survey.answers.resume||'')}</textarea>
      <div class="drop" id="drop">📄 …or drop a PDF / Word / .txt file (parsed on your device)
        <input type="file" id="file" accept=".pdf,.docx,.txt" style="display:none"></div>
      <button class="skip" id="skipResume">Skip — just use my answers</button>`;
  }

  const html = `<div class="q" id="qcard">
      <div class="qnum">${q.num}</div>
      <div class="qtitle">${q.title}</div>
      <div class="qhint">${q.hint||''}</div>
      ${body}
    </div>`;

  // transition out then in
  const old = stage.querySelector(".q");
  if(old){ old.classList.add("leaving"); setTimeout(()=>{ stage.innerHTML=html; wire(q); }, 200); }
  else { stage.innerHTML=html; wire(q); }
}

function wire(q){
  if(q.type==="single"){
    $("stage").querySelectorAll(".opt").forEach(b=> b.onclick=()=>{
      survey.answers[q.id]=b.dataset.v;
      $("stage").querySelectorAll(".opt").forEach(x=>x.classList.remove("sel"));
      b.classList.add("sel");
    });
  } else if(q.type==="text"){
    const inp=$("txtIn"); inp.focus();
    inp.oninput=()=>survey.answers[q.id]=inp.value;
    inp.onkeydown=e=>{ if(e.key==="Enter") $("nextBtn").click(); };
  } else if(q.type==="textarea"){
    const ta=$("taIn"); ta.focus();
    ta.oninput=()=>survey.answers[q.id]=ta.value;
  } else if(q.type==="resume"){
    const ta=$("resIn"); ta.oninput=()=>survey.answers.resume=ta.value;
    const drop=$("drop"), file=$("file");
    drop.onclick=()=>file.click();
    drop.ondragover=e=>{e.preventDefault();drop.classList.add("drag");};
    drop.ondragleave=()=>drop.classList.remove("drag");
    drop.ondrop=e=>{e.preventDefault();drop.classList.remove("drag");if(e.dataTransfer.files[0])readResume(e.dataTransfer.files[0]);};
    file.onchange=e=>{if(e.target.files[0])readResume(e.target.files[0]);};
    $("skipResume").onclick=()=>{ survey.answers.resume=""; finish(); };
  }
}

async function readResume(f){
  const ext=f.name.split(".").pop().toLowerCase();
  const drop=$("drop");
  try{
    if(ext==="txt"){ survey.answers.resume=(await f.text()).trim(); }
    else if(ext==="pdf"){
      if(!window.pdfjsLib){ await loadScript("https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"); pdfjsLib.GlobalWorkerOptions.workerSrc="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js"; }
      const buf=await f.arrayBuffer(); const pdf=await pdfjsLib.getDocument({data:buf}).promise; let t="";
      for(let i=1;i<=pdf.numPages;i++){ const p=await pdf.getPage(i); const ct=await p.getTextContent(); t+=ct.items.map(x=>x.str).join(" ")+"\n"; }
      survey.answers.resume=t.trim();
    } else if(ext==="docx"){
      if(!window.mammoth){ await loadScript("https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.6.0/mammoth.browser.min.js"); }
      const buf=await f.arrayBuffer(); const r=await mammoth.extractRawText({arrayBuffer:buf}); survey.answers.resume=r.value.trim();
    } else { drop.textContent="Unsupported file — paste the text instead."; return; }
    if($("resIn")) $("resIn").value=survey.answers.resume;
    drop.textContent="✓ Loaded "+f.name+" — click “See my matches”.";
  }catch(e){ drop.textContent="⚠ Couldn't read that file — paste the text instead."; }
}
function loadScript(src){ return new Promise((res,rej)=>{ const s=document.createElement("script"); s.src=src; s.onload=res; s.onerror=rej; document.head.appendChild(s); }); }

$("nextBtn").onclick=()=>{
  const q=survey.questions[step];
  // light validation
  if(q.type==="single" && !survey.answers[q.id]) { flash(); return; }
  if(q.id==="major" && !survey.answers.major.trim()) { flash(); return; }
  if(step===survey.questions.length-1){ finish(); return; }
  step++; renderStep(1);
};
$("backBtn").onclick=()=>{ if(step>0){ step--; renderStep(-1); } };
function flash(){ const n=$("nextBtn"); n.style.background="#b3402f"; setTimeout(()=>n.style.background="",350); }

/* ---------------- matching ---------------- */
const SKILLS=["excel","powerpoint","sql","python","r","tableau","power bi","financial modeling","valuation","market research","statistics","machine learning","data analysis","data visualization","project management","lean six sigma","six sigma","salesforce","sap","aws","azure","agile","scrum","leadership","java","javascript","matlab","process improvement","supply chain","industrial engineering","business analytics","economics","finance","accounting","computer science","information systems","marketing","consulting","operations","optimization","simulation","cybersecurity","cloud","product management","biology","chemistry","pharma","clinical","healthcare"];
function norm(t){return (" "+t.toLowerCase()+" ").replace(/[^a-z0-9+#&. ]/g," ").replace(/\s+/g," ");}

// Map a free-text major string to the canonical major TAGS used on each internship.
const MAJOR_ALIASES=[
  [/(business analytic|bus.*analytic|\bba\b)/,"business_analytics"],
  [/(data scien|\bds\b|machine learning|\bai\b|artificial intelligence)/,"data_science"],
  [/(information system|\bmis\b|info system|business technolog)/,"information_systems"],
  [/(industrial eng|\bisye\b|\bie\b|systems eng)/,"industrial_engineering"],
  [/(supply chain|operations manage|logistics)/,"operations"],
  [/(computer scien|\bcs\b|software eng|comp sci|informatics)/,"computer_science"],
  [/(statistic|biostat|\bstats\b)/,"statistics"],
  [/(econ)/,"economics"],
  [/(finance|financ)/,"finance"],
  [/(account)/,"accounting"],
  [/(marketing)/,"marketing"],
  [/(\bmath|applied math|mathematic)/,"math"],
  [/(physic)/,"physics"],
  [/(industrial|mechanical|electrical|civil|chemical eng|aerospace|biomedical eng|\beng\b|engineer)/,"engineering"],
  [/(business|management|administration|\bmba\b|commerce)/,"business"],
  // majors with NO fit in the current live sections — tagged so we can recognize them but they map to nothing
  [/(biolog|chem(?!ical eng)|pre.?med|nursing|public health|kinesiolog|neuroscience|psycholog|biochem|pharm|clinical|health scien|premed|medic)/,"_nonfit_health"],
  [/(english|history|political|philosoph|sociolog|anthropolog|art|music|design|communicat|journalis|education|liberal)/,"_nonfit_humanities"]
];
function majorToTags(str){
  const t=norm(str); const tags=new Set();
  MAJOR_ALIASES.forEach(([re,tag])=>{ if(re.test(t)) tags.add(tag); });
  return [...tags];
}

function scoreItem(item, sig, userMajorTags){
  const {d,c,section}=item;
  const text=norm(d.role+" "+d.company+" "+d.about+" "+d.types.join(" ")+" "+(c.tier||"")+" "+(c.background||""));
  let score=0; const reasons=new Set();
  const itemTags=d.majorTags||[];

  // ---- MAJOR FIT (the gate) ----
  // How well does the user's major overlap with the majors this role actually recruits?
  const hasMajor = userMajorTags.length>0;
  const overlap = userMajorTags.filter(t=>itemTags.includes(t) || (itemTags.includes("any") && !t.startsWith("_nonfit")));
  const nonFitOnly = hasMajor && userMajorTags.every(t=>t.startsWith("_nonfit"));
  if(overlap.length){
    score += 5 + Math.min(overlap.length-1,2)*2;   // 5 / 7 / 9 for 1 / 2 / 3+ matched majors
    reasons.add(survey.answers.major.trim()+" fits this role");
  }
  // free-text interests
  const STOP=new Set(["with","what","want","like","into","that","this","your","working","work","about","really","interested","interest","stuff","things","also","more","some"]);
  norm(survey.answers.interests).trim().split(" ").filter(w=>w.length>3 && !STOP.has(w)).forEach(tk=>{
    if(text.includes(tk)){ score+=2; reasons.add(tk); } });
  // resume skills
  sig.forEach(s=>{ if(text.includes(s)){ score+=1.5; reasons.add(s); } });
  // company size preference
  if(survey.answers.size==="startup" && c.startup){ score+=2; reasons.add("startup"); }
  if(survey.answers.size==="large" && c.fortune){ score+=2; reasons.add("Fortune "+Math.ceil(c.fortune/100)*100); }
  // grad-level alignment
  if((survey.answers.grad==="2029"||survey.answers.grad==="2030+") && d.level && d.level.startsWith("Sophomore")) score+=1;

  // ---- PENALTY: major clearly doesn't fit ----
  // If the user gave a major and it has zero overlap with what the role recruits,
  // this is not a real match — cap it hard so unrelated majors can't show high.
  if(hasMajor && overlap.length===0){
    score = Math.min(score, 2);           // interests/skills alone can't fake a fit
    if(nonFitOnly) score = Math.min(score, 1);
  }
  return {score, reasons:[...reasons].slice(0,6)};
}

function finish(){
  const sig=new Set();
  const rtext=norm(survey.answers.resume||"");
  SKILLS.forEach(s=>{ if(rtext.includes(s)) sig.add(s); });

  const userMajorTags=majorToTags(survey.answers.major||"");
  const pool=buildPool();
  const scored=pool.map(item=>({item, ...scoreItem(item, sig, userMajorTags)}));
  // Absolute scoring: a match must actually be relevant to score high.
  // Major fit is the backbone (up to 9), so a non-fitting major caps out low.
  const TARGET=13; // a score this high reads as an excellent fit
  scored.forEach(s=> s.pct = Math.max(0, Math.min(96, Math.round((s.score/TARGET)*100))));
  scored.sort((a,b)=> b.score-a.score || a.item.d.company.localeCompare(b.item.d.company));
  // Only surface genuinely relevant matches; if almost nothing fits, show the closest few honestly.
  let top=scored.filter(s=> s.pct>=40).slice(0,24);
  if(top.length<3) top=scored.filter(s=>s.score>0 && s.pct>=20).slice(0,6);

  // UI swap
  $("survey").style.display="none";
  const res=$("results"); res.style.display="block";

  const detected=[...sig];
  const tagBits=[];
  if(survey.answers.field) tagBits.push(({business:"Business",cs:"CS & Tech",engineering:"Engineering",med:"Healthcare",unsure:"Exploring"})[survey.answers.field]);
  if(survey.answers.major) tagBits.push(survey.answers.major.trim());
  if(survey.answers.grad) tagBits.push("Grad "+survey.answers.grad);
  if(survey.answers.size && survey.answers.size!=="any") tagBits.push(survey.answers.size==="startup"?"Startups":"Fortune 500");
  detected.slice(0,10).forEach(s=>tagBits.push(s));
  $("yourtags").innerHTML = tagBits.map(t=>`<span class="yt">${t}</span>`).join("");

  $("rsub").textContent = top.length
    ? `${top.length} relevant ${top.length===1?"internship":"internships"} for you, drawn from the ${pool.length} programs across our live sections. As more fields go live, your matches grow.`
    : `No close matches in our live sections yet — only Consulting and Data & Business Analytics are live right now. As more fields go live, your matches will grow.`;

  const emptyNote = `<div class="note">No strong matches yet. The live sections (Consulting, Data &amp; Business Analytics) may not line up with what you entered — try editing your interests or major, or check back as more fields go live.</div>`;
  $("rlist").innerHTML = `<div class="note">Only Consulting and Data &amp; Business Analytics are live so far, so matches come from those. More fields are coming — retake the survey later for fresh results.</div>` +
    (top.length ? "" : emptyNote) +
    top.map(s=>{
      const {d,c,section}=s.item; const cls=s.pct>=80?"hi":s.pct>=60?"mid":"lo";
      const why = s.reasons.length ? s.reasons.map(r=>`<span class="mk">${r}</span>`).join("") : `<span class="why">Broadly relevant to your answers.</span>`;
      const live=/^open[\s(]/i.test(d.status||"");
      return `<div class="rcard">
        <div class="score ${cls}">${s.pct}%</div>
        <span class="sectlabel">${section}</span>
        <div class="rco">${d.company}</div>
        <div class="rrole">${d.role}</div>
        <div class="rmeta">${(c.tier||"")} · 🗓 ${d.due||"—"} · 💵 ${d.comp||"—"}</div>
        <div class="why"><b style="color:#cdd3dc">Why it fits:</b></div><div>${why}</div>
        ${live?`<a class="rapply" href="${d.applyUrl}" target="_blank" rel="noopener">Go to application →</a>`:`<span class="why" style="color:var(--gold)">🔜 Application not open yet — coming soon</span>`}
      </div>`;
    }).join("");
  window.scrollTo({top:0,behavior:"smooth"});
}

$("restartBtn").onclick=()=>{
  step=0; survey.answers={ field:null, major:"", interests:"", grad:null, size:null, location:null, resume:"" };
  $("results").style.display="none"; $("survey").style.display="block"; renderStep(1);
  window.scrollTo({top:0,behavior:"smooth"});
};

renderStep(1);
</script>
<script type="module" src="firebase-auth.js"></script>
<script type="module" src="account-widget.js"></script>
<script type="module">
  // Personalized survey requires sign-in.
  (function(){
    const gate = document.getElementById("authGate");
    let settled=false, tries=0;
    function prompt(){
      gate.innerHTML = `
        <div style="font-size:18px;font-weight:700">🔒 Sign in to get personalized matches</div>
        <div style="font-size:14px;color:#9aa4b2;max-width:430px">The personalized survey is account-only so your matches and resume can follow you across devices. It's free and quick.</div>
        <a href="login.html?return=survey.html" style="margin-top:6px;background:#5b8cff;color:#fff;text-decoration:none;font-weight:650;font-size:14px;padding:11px 22px;border-radius:11px">Log in or create an account →</a>
        <a href="database.html" style="color:#9aa4b2;font-size:13px;text-decoration:underline">Or browse the whole database without an account</a>`;
    }
    function ready(cb){ if(window.AIF_AUTH) return cb(); if(tries++>75){ prompt(); return; } setTimeout(()=>ready(cb),40); }
    ready(()=>{ window.AIF_AUTH.onUser(u=>{ settled=true; if(u){ gate.style.display="none"; } else { window.location.href="login.html?return=survey.html"; } }); });
    setTimeout(()=>{ if(!settled && !window.AIF_AUTH) prompt(); }, 3500);
  })();
</script>
</body>
</html>
